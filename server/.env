# Variáveis de ambiente para o servidor Express/Socket.IO
NODE_ENV=development
FRONTEND_URL=http://localhost/webrtc/
SERVER_URL=http://localhost:3000

# Porta onde o servidor Express/Socket.IO vai rodar
PORT=3000

# Origem permitida para o CORS (pode ser o seu localhost do frontend ou o domínio de produção)
# Para permitir qualquer um, mantenha *
CORS_ORIGIN=*
# Exemplo para produção: CORS_ORIGIN=https://seu-chat-app.netlify.app